; Engine configuration file.
; Vampire Survivors (WIP) — Milestone 3: Classes (Ranged vs Melee)

config_version=5

[application]

config/name="Survivors Prototype"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

Config="*res://src/autoload/config.gd"
Fx="*res://src/autoload/fx.gd"
Save="*res://src/autoload/save.gd"
Sim="*res://src/autoload/sim.gd"
RunLog="*res://src/autoload/runlog.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=2
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

environment/defaults/default_clear_color=Color(0.07, 0.07, 0.1, 1)
