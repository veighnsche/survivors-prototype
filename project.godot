; Engine configuration file.
; Vampire Survivors (WIP) — Milestone 3: Classes (Ranged vs Melee)

config_version=5

[application]

config/name="Survivors Prototype"
run/main_scene="res://main_menu.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

Config="*res://scripts/config.gd"
Fx="*res://scripts/fx.gd"
Save="*res://scripts/save.gd"
Sim="*res://scripts/sim.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1500
window/size/window_height_override=844
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

environment/defaults/default_clear_color=Color(0.07, 0.07, 0.1, 1)
